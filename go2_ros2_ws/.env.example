# Copy this file to go2_ros2_ws/.env and set your host network interface.
# This file is loaded by go2_ros2_ws/scripts/run.sh and passed into the container.

# Network interface used to communicate with the robot
CYCLONEDDS_IFACE=enp0s31f6

# Motion capture VRPN server IP address
MOCAP_IP=192.168.50.86
